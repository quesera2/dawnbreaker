{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'config:recommended',
  ],
  labels: [
    'renovate',
  ],
  timezone: 'Asia/Tokyo',
  schedule: [
    'before 9am',
  ],
  prHourlyLimit: 3,
  prConcurrentLimit: 10,
  minimumReleaseAge: '3 days',
  packageRules: [
    {
      matchPackageNames: [
        'dev.flutter.flutter-plugin-loader.gradle.plugin',
      ],
      enabled: false,
    },
    {
      matchManagers: [
        'pub',
      ],
      groupName: 'Firebase Flutter packages',
      matchPackageNames: [
        'firebase_{/,}**',
      ],
    },
    {
      matchManagers: [
        'gradle',
      ],
      groupName: 'Firebase Gradle plugins',
      matchPackageNames: [
        'com.google.firebase{/,}**',
        'com.google.gms{/,}**',
      ],
    },
  ],
}
